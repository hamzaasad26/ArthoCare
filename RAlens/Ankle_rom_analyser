def rrect(img, x1, y1, x2, y2, r, color, alpha=0.78):
    ov = img.copy()
    cv2.rectangle(ov, (x1+r, y1), (x2-r, y2), color, -1)
    cv2.rectangle(ov, (x1, y1+r), (x2, y2-r), color, -1)
    for cx, cy in [(x1+r,y1+r),(x2-r,y1+r),(x1+r,y2-r),(x2-r,y2-r)]:
        cv2.circle(ov, (cx,cy), r, color, -1)
    cv2.addWeighted(ov, alpha, img, 1-alpha, 0, img)


def t(img, text, x, y, sc=0.55, col=CW, th=1, bold=False):
    f = cv2.FONT_HERSHEY_DUPLEX
    if bold:
        cv2.putText(img, text, (x, y), f, sc, (0,0,0), th+2)
    cv2.putText(img, text, (x, y), f, sc, col, th)


def draw_ankle_gauge(img, cx, cy, rad, dorsi_val, plantar_val):
    """
    Arc gauge:
    Top half  = dorsiflexion  (toes up,   green)
    Bottom half = plantarflexion (toes down, purple)
    """
    # Background arcs
    cv2.ellipse(img, (cx,cy), (rad,rad), -90, 0,   70, (50,50,50), 8, cv2.LINE_AA)  # dorsi range
    cv2.ellipse(img, (cx,cy), (rad,rad), -90, -70,  0, (50,50,50), 8, cv2.LINE_AA)  # plantar range

    # Filled arcs
    if dorsi_val > 1:
        dv = int(min(dorsi_val / THRESH['dorsi_normal'] * 70, 70))
        cv2.ellipse(img, (cx,cy), (rad,rad), -90, 0, dv, CG, 8, cv2.LINE_AA)

    if plantar_val > 1:
        pv = int(min(plantar_val / THRESH['plantar_normal'] * 70, 70))
        cv2.ellipse(img, (cx,cy), (rad,rad), -90, -pv, 0, CPP, 8, cv2.LINE_AA)

    # Center dot
    cv2.circle(img, (cx, cy), 6, CW, -1, cv2.LINE_AA)


def draw_skeleton_live(frame, pose_lm, side, w, h):
    P = mp.solutions.pose.PoseLandmark
    if side == 'left':
        ki, ai, fi = P.LEFT_KNEE.value, P.LEFT_ANKLE.value, P.LEFT_FOOT_INDEX.value
    else:
        ki, ai, fi = P.RIGHT_KNEE.value, P.RIGHT_ANKLE.value, P.RIGHT_FOOT_INDEX.value
    lm = pose_lm.landmark
    kp = (int(lm[ki].x*w), int(lm[ki].y*h))
    ap = (int(lm[ai].x*w), int(lm[ai].y*h))
    fp = (int(lm[fi].x*w), int(lm[fi].y*h))
    # glow
    cv2.line(frame, kp, ap, (0,70,0),   10, cv2.LINE_AA)
    cv2.line(frame, ap, fp, (100,50,0),  9, cv2.LINE_AA)
    cv2.line(frame, kp, ap, CG,  4, cv2.LINE_AA)
    cv2.line(frame, ap, fp, CO,  3, cv2.LINE_AA)
    for pt, col, r in [(kp,CY,9),(ap,CC,13),(fp,CO,9)]:
        cv2.circle(frame, pt, r+3, (0,0,0), -1, cv2.LINE_AA)
        cv2.circle(frame, pt, r,   col,     -1, cv2.LINE_AA)


