def save_report(folder, pid, left_r: Optional[AnkleResult],
                right_r: Optional[AnkleResult]):
    os.makedirs(folder, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # JSON
    bilateral = None
    if left_r and right_r:
        dd = abs(left_r.max_dorsiflexion   - right_r.max_dorsiflexion)
        dp = abs(left_r.max_plantarflexion - right_r.max_plantarflexion)
        bilateral = {
            "dorsiflexion_difference_deg":   round(dd, 1),
            "plantarflexion_difference_deg": round(dp, 1),
            "asymmetry_flag":                dd > 10 or dp > 15,
            "clinical_note": "Difference >10° dorsi or >15° plantar is clinically significant."
        }

    jp = os.path.join(folder, f"{pid}_ankle_report.json")
    with open(jp, 'w') as f:
        json.dump({
            "patient_id":   pid,
            "test_date":    ts,
            "standard":     "AAOS / AMA Guides 6th Edition — Ankle ROM",
            "left_ankle":   asdict(left_r)  if left_r  else None,
            "right_ankle":  asdict(right_r) if right_r else None,
            "bilateral_comparison": bilateral,
            "normal_reference": {
                "dorsiflexion_normal_deg":    THRESH['dorsi_normal'],
                "dorsiflexion_flag_deg":      THRESH['dorsi_flag'],
                "dorsiflexion_severe_deg":    THRESH['dorsi_severe'],
                "plantarflexion_normal_deg":  THRESH['plantar_normal'],
                "plantarflexion_flag_deg":    THRESH['plantar_flag'],
                "plantarflexion_severe_deg":  THRESH['plantar_severe'],
                "ama_max_le_contribution_pct": 7.0,
            }
        }, f, indent=2)

    # TXT
    SEP = "=" * 64
    tp  = os.path.join(folder, f"{pid}_ankle_summary.txt")
    with open(tp, 'w', encoding='utf-8') as f:
        f.write(SEP + "\n  ANKLE ROM ANALYSIS REPORT\n")
        f.write("  Standard: AAOS / AMA Guides 6th Edition\n" + SEP + "\n")
        f.write(f"  Patient ID  : {pid}\n  Test Date   : {ts}\n" + SEP + "\n\n")

        for res, lbl in [(left_r,"LEFT ANKLE"), (right_r,"RIGHT ANKLE")]:
            if not res:
