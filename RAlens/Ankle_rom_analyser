def annotated_capture(frame, pose_lm, side, raw_angle, dev,
                      state, w, h) -> np.ndarray:
    img = frame.copy()
    P   = mp.solutions.pose.PoseLandmark
    if side == 'left':
        ki, ai, fi = P.LEFT_KNEE.value, P.LEFT_ANKLE.value, P.LEFT_FOOT_INDEX.value
    else:
        ki, ai, fi = P.RIGHT_KNEE.value, P.RIGHT_ANKLE.value, P.RIGHT_FOOT_INDEX.value

    lm = pose_lm.landmark
    kp = (int(lm[ki].x * w), int(lm[ki].y * h))
    ap = (int(lm[ai].x * w), int(lm[ai].y * h))
    fp = (int(lm[fi].x * w), int(lm[fi].y * h))

    # Skeleton lines
    cv2.line(img, kp, ap, (0, 200, 0),   3, cv2.LINE_AA)
    cv2.line(img, ap, fp, (255, 160, 0), 3, cv2.LINE_AA)

    # Joint circles + coord labels
    for pt, col, name in [(kp, (0,220,220), "Knee"),
                           (ap, (0,255,0),  "Ankle"),
                           (fp, (255,180,0),"FootTip")]:
        cv2.circle(img, pt, 10, (0,0,0), -1, cv2.LINE_AA)
        cv2.circle(img, pt,  7, col,     -1, cv2.LINE_AA)
        cv2.putText(img, f"{name} ({pt[0]},{pt[1]})",
                    (pt[0]+12, pt[1]+5), cv2.FONT_HERSHEY_SIMPLEX,
                    0.42, col, 1, cv2.LINE_AA)

    # Angle annotation at ankle
    direction = "UP" if dev >= 0 else "DOWN"
    cv2.putText(img, f"Raw: {raw_angle:.1f} deg  Dev: {abs(dev):.1f} deg {direction}",
                (ap[0]+10, ap[1]-18), cv2.FONT_HERSHEY_DUPLEX,
                0.65, (0,255,255), 1, cv2.LINE_AA)

    # Angle arc at ankle
    arc_deg = int(min(abs(dev), 60))
    if arc_deg > 2:
        cv2.ellipse(img, ap, (50,50), 0, -90, -90 + arc_deg,
                    (0,255,255), 2, cv2.LINE_AA)

    # Header bar
    cv2.rectangle(img, (0,0), (w,52), (0,0,0), -1)
    ts = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
    cv2.putText(img, f"{side.upper()} Ankle — {state.name}  |  raw {raw_angle:.1f}°  dev {dev:+.1f}°",
                (10, 20), cv2.FONT_HERSHEY_DUPLEX, 0.50, (0,220,220), 1)
    cv2.putText(img, ts, (10, 44),
                cv2.FONT_HERSHEY_DUPLEX, 0.42, (155,155,155), 1)

    # Landmark table bottom-right
    rows = [
        f"Knee    x={lm[ki].x:.3f}  y={lm[ki].y:.3f}  z={lm[ki].z:.3f}",
        f"Ankle   x={lm[ai].x:.3f}  y={lm[ai].y:.3f}  z={lm[ai].z:.3f}",
        f"FootTip x={lm[fi].x:.3f}  y={lm[fi].y:.3f}  z={lm[fi].z:.3f}",
    ]
    by = h - 10 - len(rows) * 20
    cv2.rectangle(img, (w-384, by-8), (w-2, h-2), (20,20,20), -1)
    for i, row in enumerate(rows):
        cv2.putText(img, row, (w-380, by + i*20),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.38, (175,175,175), 1)
    return img


# ═══════════════════════════════════════════════════════════════
