# ═══════════════════════════════════════════════════════════════
#  GEOMETRY — Ankle angle
# ═══════════════════════════════════════════════════════════════

def ankle_angle_raw(knee, ankle, foot_index) -> float:
    """
    Returns the angle at the ankle joint (knee-ankle-foot).
    90° = foot perfectly perpendicular to shin (neutral)
    < 90° = dorsiflexion (toes up, shin and foot angle narrows)
    > 90° = plantarflexion (toes pointed, angle opens past 90)

    We use the foot_index landmark (toe tip) as the foot vector endpoint.
    """
    v1 = knee       - ankle
    v2 = foot_index - ankle
    n1, n2 = np.linalg.norm(v1), np.linalg.norm(v2)
    if n1 < 1e-6 or n2 < 1e-6:
        return 90.0
    cos_a = np.clip(np.dot(v1 / n1, v2 / n2), -1.0, 1.0)
    return np.degrees(np.arccos(cos_a))


def deviation_from_neutral(raw_angle: float, neutral: float) -> float:
    """
    Returns signed deviation from neutral:
    positive = dorsiflexion (foot angle < neutral → toes up)
    negative = plantarflexion (foot angle > neutral → toes pointed)
    """
    return neutral - raw_angle


# ═══════════════════════════════════════════════════════════════
#  LANDMARK HELPER
# ═══════════════════════════════════════════════════════════════

def get_foot(pose_lm, side: str):
    """
    Returns knee, ankle, foot_index numpy arrays.
    For side-profile testing: patient's tested side faces camera.
    Camera is flipped so MediaPipe side matches patient's visible side.
    """
    P = mp.solutions.pose.PoseLandmark
    if side == 'left':
        ki  = P.LEFT_KNEE.value
        ai  = P.LEFT_ANKLE.value
        fi  = P.LEFT_FOOT_INDEX.value
        hi  = P.LEFT_HIP.value
    else:
        ki  = P.RIGHT_KNEE.value
        ai  = P.RIGHT_ANKLE.value
        fi  = P.RIGHT_FOOT_INDEX.value
        hi  = P.RIGHT_HIP.value

    lm  = pose_lm.landmark
    kp  = np.array([lm[ki].x, lm[ki].y, lm[ki].z])
    ap  = np.array([lm[ai].x, lm[ai].y, lm[ai].z])
    fp  = np.array([lm[fi].x, lm[fi].y, lm[fi].z])
    hp  = np.array([lm[hi].x, lm[hi].y, lm[hi].z])
    vis = min(lm[ki].visibility, lm[ai].visibility, lm[fi].visibility)
    return kp, ap, fp, hp, vis, ki, ai, fi


# ═══════════════════════════════════════════════════════════════
#  POSTURE VALIDATION + DIRECTIONAL GUIDANCE
# ═══════════════════════════════════════════════════════════════

def validate(raw_angle: float, neutral: float,
             state: TestState) -> Tuple[bool, str, str]:
    """
    Returns (ok, status_message, direction_hint).
    raw_angle = knee-ankle-foot angle in degrees.
    neutral   = baseline angle captured at start.
    deviation = neutral - raw_angle
                positive → dorsiflexion
                negative → plantarflexion
    """
    if state == TestState.NEUTRAL_BASELINE:
        # Foot should be roughly 90° (perpendicular to shin)
        if THRESH['neutral_min'] <= raw_angle <= THRESH['neutral_max']:
            return True,  f"Good neutral position  ({raw_angle:.0f}°)", ""
        elif raw_angle < THRESH['neutral_min']:
            diff = THRESH['neutral_min'] - raw_angle
            return False, f"Foot too dorsiflexed  ({raw_angle:.0f}°  need 80-100°)", \
                          f"  Relax foot — let it hang naturally"
        else:
            diff = raw_angle - THRESH['neutral_max']
            return False, f"Foot too plantarflexed  ({raw_angle:.0f}°  need 80-100°)", \
                          f"  Bring toes up slightly — relax foot"

    dev = deviation_from_neutral(raw_angle, neutral)

    if state == TestState.DORSIFLEXION_TEST:
        # Want deviation to be positive and large (toes up)
        if dev >= THRESH['dorsi_flag']:
            return True,  f"Good dorsiflexion  ({dev:.0f}° up)", ""
        elif dev >= 5:
            return True,  f"Keep pulling toes up  ({dev:.0f}°)", \
                          f"  Pull toes further toward shin"
        else:
            return False, f"Pull toes UP toward shin  ({dev:.0f}°  need > 5°)", \
                          f"  Flex foot upward — bring toes toward knee"

    elif state == TestState.PLANTAR_TEST:
        # Want deviation to be negative and large (toes down / pointed)
        plantar_val = -dev   # make positive for display
        if plantar_val >= THRESH['plantar_flag']:
            return True,  f"Good plantarflexion  ({plantar_val:.0f}° down)", ""
        elif plantar_val >= 15:
            return True,  f"Keep pointing toes  ({plantar_val:.0f}°)", \
                          f"  Point foot further down like ballet"
        else:
            return False, f"Point toes DOWN  ({plantar_val:.0f}°  need > 15°)", \
                          f"  Push foot down — point toes toward floor"

    return True, "Position OK", ""


# ═══════════════════════════════════════════════════════════════
#  MEDICAL GRADING
# ═══════════════════════════════════════════════════════════════

def grade_dorsiflexion(angle_deg: float) -> Tuple[str, float, str]:
    """angle_deg = deviation above neutral (positive = toes up)"""
    deficit = max(0.0, THRESH['dorsi_normal'] - angle_deg)
    if angle_deg >= THRESH['dorsi_flag']:
        return "NORMAL",   deficit, "Dorsiflexion within AAOS normal limits."
    elif angle_deg >= THRESH['dorsi_severe']:
        return "MILD",     deficit, f"Mild dorsiflexion restriction — {deficit:.0f}° below normal."
    else:
        return "SEVERE",   deficit, f"Severe dorsiflexion restriction — {deficit:.0f}° deficit. Urgent evaluation."


def grade_plantarflexion(angle_deg: float) -> Tuple[str, float, str]:
    """angle_deg = deviation below neutral (positive = toes down)"""
    deficit = max(0.0, THRESH['plantar_normal'] - angle_deg)
    if angle_deg >= THRESH['plantar_flag']:
        return "NORMAL",   deficit, "Plantarflexion within AAOS normal limits."
    elif angle_deg >= THRESH['plantar_severe']:
        return "MILD",     deficit, f"Mild plantarflexion restriction — {deficit:.0f}° below normal."
    else:
        return "SEVERE",   deficit, f"Severe plantarflexion restriction — {deficit:.0f}° deficit."


def estimate_impairment(total_arc: float) -> float:
    """AMA Guides 6th Ed. — max ankle lower-extremity contribution ~7%."""
    full_arc = 70.0   # 20° dorsi + 50° plantar
    return round(max(0.0, (1.0 - min(total_arc / full_arc, 1.0)) * 7.0), 1)


