# ═══════════════════════════════════════════════════════════════
#  SINGLE FOOT ANALYZER
# ═══════════════════════════════════════════════════════════════

class FootAnalyzer:
    def __init__(self, cap, pose, side, pid, out):
        self.cap         = cap
        self.pose        = pose
        self.side        = side
        self.pid         = pid
        self.out         = out
        self.state       = TestState.NEUTRAL_BASELINE
        self.neutral     = 90.0   # default neutral, overwritten at baseline
        self.max_dorsi   = 0.0
        self.max_plantar = 0.0
        self.buf         = deque(maxlen=STAB['buf'])
        self.hist        = []
        self.hold_t      = None

    def _stable(self, a):
        self.buf.append(a)
        if len(self.buf) < STAB['buf']:
            return False
        return float(np.var(list(self.buf))) < STAB['variance']

    def _plateaued(self, a):
        if self.state not in (TestState.DORSIFLEXION_TEST, TestState.PLANTAR_TEST):
            return True
        self.hist.append(a)
        if len(self.hist) > STAB['plateau_win']:
            self.hist.pop(0)
        if len(self.hist) < STAB['plateau_win']:
            return False
        recent  = float(np.mean(self.hist[-5:]))
        earlier = float(np.mean(self.hist[:5]))
        return abs(recent - earlier) < STAB['plateau_tol']

    def _capture_advance(self, frame, pose_lm, raw_angle, dev):
        ann = annotated_capture(frame, pose_lm, self.side,
                                raw_angle, dev, self.state, WINDOW_W, WINDOW_H)
        fname = os.path.join(
            self.out,
            f"{self.pid}_{self.side}_{self.state.name}_{abs(dev):.0f}deg.jpg"
        )
        cv2.imwrite(fname, ann)
        print(f"  📸 {fname}")

        if   self.state == TestState.NEUTRAL_BASELINE:
            self.neutral = raw_angle
            self.state   = TestState.DORSIFLEXION_TEST
        elif self.state == TestState.DORSIFLEXION_TEST:
            self.state   = TestState.PLANTAR_TEST
        elif self.state == TestState.PLANTAR_TEST:
            self.state   = TestState.COMPLETE

        self.hold_t = None
        self.buf.clear()
        self.hist.clear()

    def _show_intro(self):
        deadline = time.time() + 2.5
        while time.time() < deadline:
            ret, raw = self.cap.read()
            frame = cv2.resize(
                cv2.flip(raw, 1) if ret else np.zeros((WINDOW_H,WINDOW_W,3), np.uint8),
                (WINDOW_W, WINDOW_H)
            )
            ov = frame.copy()
            cv2.rectangle(ov, (0,0),(WINDOW_W,WINDOW_H),(0,0,0),-1)
            cv2.addWeighted(ov, 0.72, frame, 0.28, 0, frame)

            bc = (155,48,0) if self.side=='left' else (0,68,155)
            rrect(frame, WINDOW_W//2-240, WINDOW_H//2-80,
                  WINDOW_W//2+240, WINDOW_H//2+80, 16, bc, alpha=0.92)
            t(frame, f"Testing  {self.side.upper()}  ANKLE",
              WINDOW_W//2-195, WINDOW_H//2-25, 0.88, CW, 2, bold=True)
            t(frame, f"Sit on chair — {self.side.upper()} side to camera",
              WINDOW_W//2-220, WINDOW_H//2+20, 0.56, CW, 1)
            t(frame, "Foot hanging free (not touching floor)",
              WINDOW_W//2-210, WINDOW_H//2+52, 0.50, (180,180,180), 1)
            t(frame, "Full lower leg visible in frame",
              WINDOW_W//2-180, WINDOW_H//2+74, 0.46, (150,150,150), 1)

            cv2.imshow("Ankle ROM Analyzer", frame)
            if (cv2.waitKey(40) & 0xFF) == ord('q'):
                return False
        return True

    def run(self) -> Optional[AnkleResult]:
        if not self._show_intro():
            return None

        while True:
            ret, raw = self.cap.read()
            if not ret:
                break

            raw   = cv2.flip(raw, 1)
            frame = cv2.resize(raw, (WINDOW_W, WINDOW_H))
            rgb   = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            res   = self.pose.process(rgb)

            # COMPLETE → show report
            if self.state == TestState.COMPLETE:
                result   = analyze(self.neutral, self.max_dorsi,
                                   self.max_plantar, self.side)
                deadline = time.time() + REPORT_SECS
                while time.time() < deadline:
                    sl = deadline - time.time()
                    cv2.imshow("Ankle ROM Analyzer",
                               draw_report_screen(result, sl))
                    k = cv2.waitKey(40) & 0xFF
                    if k == ord('q'):
                        return result
                return result

            # ACTIVE TEST
            if res.pose_landmarks:
                kp, ap, fp, hp, vis, *_ = get_foot(res.pose_landmarks, self.side)

                if vis > 0.30:
                    raw_angle = ankle_angle_raw(kp, ap, fp)
                    dev       = deviation_from_neutral(raw_angle, self.neutral)

                    # Track maxima
                    if self.state == TestState.DORSIFLEXION_TEST:
                        self.max_dorsi   = max(self.max_dorsi,   dev)
                    if self.state == TestState.PLANTAR_TEST:
                        self.max_plantar = max(self.max_plantar, -dev)

                    ok, msg, hint = validate(raw_angle, self.neutral, self.state)
                    stable    = self._stable(raw_angle)
                    plateaued = self._plateaued(raw_angle)
                    ready     = ok and stable and plateaued

                    countdown = None
                    if ready:
                        if self.hold_t is None:
                            self.hold_t = time.time()
                        remaining = STAB['hold_sec'] - (time.time() - self.hold_t)
                        countdown = max(0.0, remaining)
                        if remaining <= 0:
                            self._capture_advance(frame.copy(),
                                                  res.pose_landmarks,
                                                  raw_angle, dev)
                            continue
                    else:
                        self.hold_t = None

                    frame = draw_live(
                        frame, res.pose_landmarks, raw_angle, dev,
                        self.state, self.side,
                        ok, msg, hint,
                        max(0.0, self.max_dorsi),
                        max(0.0, self.max_plantar),
                        countdown, stable, WINDOW_W, WINDOW_H
                    )
                else:
                    rrect(frame, 8, WINDOW_H-68, 600, WINDOW_H-8, 6, (52,0,0), 0.8)
                    t(frame, "Low visibility — ensure full foot is visible in frame",
                      18, WINDOW_H-30, 0.54, CR, 2)
            else:
                rrect(frame, 8, WINDOW_H-68, 600, WINDOW_H-8, 6, (52,0,0), 0.8)
                t(frame, "Body not detected — sit closer / improve lighting",
                  18, WINDOW_H-30, 0.54, CR, 2)

            cv2.imshow("Ankle ROM Analyzer", frame)
            k = cv2.waitKey(10) & 0xFF
            if k == ord('q'):
                return None
            elif k == ord('r'):
                self.state       = TestState.NEUTRAL_BASELINE
                self.neutral     = 90.0
                self.max_dorsi   = 0.0
                self.max_plantar = 0.0
                self.buf.clear()
                self.hist.clear()
                self.hold_t = None

        return None


