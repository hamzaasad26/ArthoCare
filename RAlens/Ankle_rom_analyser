def main():
    print("\n" + "═"*54)
    print("  ANKLE ROM ANALYZER")
    print("  Rheumatoid Arthritis Detection")
    print("  Standard: AAOS / AMA Guides 6th Edition")
    print("═"*54)
    print("\n  PATIENT SETUP:")
    print("  • Sit on chair, foot hanging free (not on floor)")
    print("  • Side-profile to camera — full lower leg visible")
    print("  • Left test  → left side toward camera")
    print("  • Right test → turn around, right side to camera")
    print("═"*54)

    pid = input("\n  Patient ID (e.g. P001): ").strip()
    if not pid:
        print("  Patient ID required.")
        return

    cam = select_camera()
    out = os.path.join("ankle_output", pid)
    os.makedirs(out, exist_ok=True)

    print("\n  Connecting to camera...")
    cap = cv2.VideoCapture(cam)
    if not cap.isOpened():
        print(f"  Cannot open camera: {cam}")
        return
    ret, _ = cap.read()
    if not ret:
        print("  Camera open but no frames.")
        cap.release()
        return
    print("  Camera ready\n")

    pose = mp.solutions.pose.Pose(
        static_image_mode=False, model_complexity=1,
        min_detection_confidence=0.60, min_tracking_confidence=0.60
    )

    cv2.namedWindow("Ankle ROM Analyzer", cv2.WINDOW_NORMAL)
    cv2.resizeWindow("Ankle ROM Analyzer", WINDOW_W, WINDOW_H)

    # LEFT FOOT
    print("  Starting LEFT ankle test (automatic)...")
    left_r = FootAnalyzer(cap, pose, 'left', pid+"_L", out).run()

    # TRANSITION + RIGHT FOOT
    right_r = None
    if left_r is not None:
        if draw_transition(cap, INTER_FOOT_SEC):
            print("  Starting RIGHT ankle test (automatic)...")
            right_r = FootAnalyzer(cap, pose, 'right', pid+"_R", out).run()

    # SAVE COMBINED REPORT
    if left_r or right_r:
        print("\n  Saving combined report...")
        save_report(out, pid, left_r, right_r)
        print(f"  All files: ankle_output/{pid}/")

    cap.release()
    cv2.destroyAllWindows()
    print("  Done.\n")


if __name__ == "__main__":
    main()