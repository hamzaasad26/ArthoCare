#  CLINICAL ANALYSIS
# ═══════════════════════════════════════════════════════════════

def analyze(neutral, max_dorsi, max_plantar, side) -> AnkleResult:
    dg, dd, dn = grade_dorsiflexion(max_dorsi)
    pg, pd, pn = grade_plantarflexion(max_plantar)
    total_arc  = max_dorsi + max_plantar
    impairment = estimate_impairment(total_arc)

    abn, notes = [], []
    if dg != "NORMAL":
        abn.append(f"Reduced dorsiflexion: {max_dorsi:.0f}° [{dg}] — {dn}")
    if pg != "NORMAL":
        abn.append(f"Reduced plantarflexion: {max_plantar:.0f}° [{pg}] — {pn}")
    notes.append(dn)
    notes.append(pn)
    if not abn:
        notes.append(f"Total arc {total_arc:.0f}° — full ankle ROM maintained.")

    return AnkleResult(
        side=side, neutral_angle=neutral,
        max_dorsiflexion=max_dorsi, max_plantarflexion=max_plantar,
        dorsi_grade=dg, plantar_grade=pg,
        dorsi_deficit=dd, plantar_deficit=pd,
        total_arc=total_arc, impairment_pct=impairment,
        timestamp=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        abnormalities=abn, clinical_notes=notes
    )


