        f.write("  RECOMMENDATIONS\n  " + "─"*44 + "\n")
        if not all_abn:
            f.write("  - Ankle ROM normal bilaterally.\n")
            f.write("  - Continue current treatment plan.\n")
            f.write("  - Routine ROM check every 3 months.\n")
        else:
            severe = any("SEVERE" in a for a in all_abn)
            if severe:
                f.write("  - URGENT: Refer to rheumatologist / orthopaedic specialist.\n")
