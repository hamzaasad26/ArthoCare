def draw_live(frame, pose_lm, raw_angle, dev, state, side,
              ok, msg, hint, max_dorsi, max_plantar,
              countdown, stable, w, h):

    draw_skeleton_live(frame, pose_lm, side, w, h)

    # Angle label at ankle
    P  = mp.solutions.pose.PoseLandmark
    ai = P.LEFT_ANKLE.value if side=='left' else P.RIGHT_ANKLE.value
    lm = pose_lm.landmark
    ap = (int(lm[ai].x*w), int(lm[ai].y*h))
    dev_label = f"{abs(dev):.0f}° {'↑' if dev>=0 else '↓'}"
    t(frame, dev_label, ap[0]+14, ap[1]-14, 0.80, CY, 2, bold=True)

    # TOP BAR
    rrect(frame, 0, 0, w, 70, 0, (14,14,24), alpha=0.90)
    steps = {
        TestState.NEUTRAL_BASELINE:  ("STEP 1 / 3", "Hold foot RELAXED — perpendicular to shin (neutral)"),
        TestState.DORSIFLEXION_TEST: ("STEP 2 / 3", "Pull toes UP toward shin — dorsiflexion"),
        TestState.PLANTAR_TEST:      ("STEP 3 / 3", "Point toes DOWN as far as possible — plantarflexion"),
    }
    sl, si_ = steps.get(state, ("", ""))
    t(frame, sl,  14, 26, 0.52, CC, 1)
    t(frame, si_, 14, 56, 0.60, CW, 1)

    # Side badge
    bc = (155, 48, 0) if side == 'left' else (0, 68, 155)
    rrect(frame, w-132, 6, w-6, 64, 6, bc, alpha=0.92)
    t(frame, f"{side.upper()} FOOT", w-124, 44, 0.64, CW, 2)

    # Camera hint
    rrect(frame, w-310, 70, w-6, 108, 4, (30,30,50), alpha=0.85)
    t(frame, "Side-profile  |  Foot free (not on floor)", w-300, 96, 0.42, (180,180,180), 1)

    # ANKLE GAUGE (bottom-right)
    gcx, gcy = w-92, h-118
    draw_ankle_gauge(frame, gcx, gcy, 65, max_dorsi, max_plantar)
    t(frame, f"D:{max_dorsi:.0f}°", gcx-40, gcy+28, 0.42, CG,  1)
    t(frame, f"P:{max_plantar:.0f}°", gcx-40, gcy+48, 0.42, CPP, 1)
    t(frame, "ANKLE", gcx-28, gcy+64, 0.40, CW, 1)

    # POSTURE FEEDBACK
    fy = h - 108
    rrect(frame, 8, fy, 535, h-8, 8,
          (0,52,0) if ok else (52,0,0), alpha=0.80)
    t(frame, msg,  18, fy+30, 0.58, CG if ok else CR, 2)
    if hint:
        t(frame, hint, 18, fy+58, 0.50, CO, 1)

    # PROGRESS BARS
    rrect(frame, 8, 82, 222, 235, 8, (18,18,32), alpha=0.80)
    t(frame, "PROGRESS", 18, 106, 0.48, CC, 1)
    bw = 194

    # Dorsiflexion bar
    t(frame, f"Dorsiflexion: {max_dorsi:.0f}°", 18, 134, 0.44, CW, 1)
    dp_frac = min(max_dorsi / THRESH['dorsi_normal'], 1.0)
    cv2.rectangle(frame, (18,142), (18+bw,154), (45,45,45), -1)
    cv2.rectangle(frame, (18,142), (18+int(bw*dp_frac),154),
                  CG if max_dorsi >= THRESH['dorsi_flag'] else CO, -1)

    # Plantarflexion bar
    t(frame, f"Plantarflex:  {max_plantar:.0f}°", 18, 178, 0.44, CW, 1)
    pp_frac = min(max_plantar / THRESH['plantar_normal'], 1.0)
    cv2.rectangle(frame, (18,186), (18+bw,198), (45,45,45), -1)
    cv2.rectangle(frame, (18,186), (18+int(bw*pp_frac),198),
                  CG if max_plantar >= THRESH['plantar_flag'] else CPP, -1)

    # COUNTDOWN
    if countdown is not None and countdown > 0:
        rrect(frame, w//2-110, h//2-50, w//2+110, h//2+50, 14,
              (0, 90, 0), alpha=0.92)
        t(frame, "Capturing...", w//2-88, h//2-10, 0.72, CG, 2, bold=True)
        t(frame, f"{countdown:.1f}s", w//2-38, h//2+32, 0.80, CY, 2, bold=True)
    elif stable and ok:
        t(frame, "STABLE", w-165, 110, 0.52, CG, 2)
    else:
        t(frame, "Stabilising...", w-210, 110, 0.46, CO, 1)

    return frame


