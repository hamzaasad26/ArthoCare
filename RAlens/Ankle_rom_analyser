            f.write(f"  {lbl}\n  " + "─"*44 + "\n")
            f.write(f"  Neutral Baseline     : {res.neutral_angle:.1f}° (ideal ~90°)\n")
            f.write(f"  Max Dorsiflexion     : {res.max_dorsiflexion:.1f}°"
                    f"   (normal >= {THRESH['dorsi_normal']}°)"
                    f"   Grade: {res.dorsi_grade}"
                    f"   Deficit: {res.dorsi_deficit:.0f}°\n")
            f.write(f"  Max Plantarflexion   : {res.max_plantarflexion:.1f}°"
                    f"   (normal >= {THRESH['plantar_normal']}°)"
                    f"   Grade: {res.plantar_grade}"
                    f"   Deficit: {res.plantar_deficit:.0f}°\n")
            f.write(f"  Total Arc            : {res.total_arc:.1f}°"
                    f"   (normal >= 50°)\n")
            f.write(f"  AMA LE Impairment    : {res.impairment_pct:.1f}%"
                    f"   (normal < 1.5%)\n")
            status = "NORMAL" if not res.abnormalities else "RESTRICTION DETECTED"
            f.write(f"  Overall Status       : {status}\n")
            if res.abnormalities:
                f.write("\n  Abnormalities:\n")
                for a in res.abnormalities:
                    f.write(f"    - {a}\n")
            f.write("\n  Clinical Notes:\n")
            for n in res.clinical_notes:
                f.write(f"    {n}\n")
            f.write("\n")

        if bilateral:
            f.write("  BILATERAL COMPARISON\n  " + "─"*44 + "\n")
            f.write(f"  Dorsiflexion  diff : {bilateral['dorsiflexion_difference_deg']:.1f}°"
