def annotated_capture(frame, pose_lm, side, angle, state, w, h) -> np.ndarray:
    img = frame.copy()
    P   = mp.solutions.pose.PoseLandmark
    if side == 'left':
        hi, ki, ai = P.LEFT_HIP.value, P.LEFT_KNEE.value, P.LEFT_ANKLE.value
    else:
        hi, ki, ai = P.RIGHT_HIP.value, P.RIGHT_KNEE.value, P.RIGHT_ANKLE.value
    lm = pose_lm.landmark
    hp = (int(lm[hi].x * w), int(lm[hi].y * h))
    kp = (int(lm[ki].x * w), int(lm[ki].y * h))
    ap = (int(lm[ai].x * w), int(lm[ai].y * h))

    # Skeleton lines
    cv2.line(img, hp, kp, (0, 200, 0),   3, cv2.LINE_AA)
    cv2.line(img, kp, ap, (0, 160, 220), 3, cv2.LINE_AA)

    # Joint circles + coordinate labels
    for pt, col, name in [(hp, (0,220,220), "Hip"),
                           (kp, (0,255,0),  "Knee"),
                           (ap, (255,180,0),"Ankle")]:
        cv2.circle(img, pt, 10, (0,0,0), -1, cv2.LINE_AA)
        cv2.circle(img, pt,  7, col,     -1, cv2.LINE_AA)
        cv2.putText(img, f"{name} ({pt[0]},{pt[1]})",
                    (pt[0]+12, pt[1]+5), cv2.FONT_HERSHEY_SIMPLEX,
                    0.42, col, 1, cv2.LINE_AA)

    # Angle at knee
    cv2.putText(img, f"{angle:.1f} deg",
                (kp[0]+16, kp[1]-18), cv2.FONT_HERSHEY_DUPLEX,
                0.9, (0,255,255), 2, cv2.LINE_AA)
    if angle > 3:
        cv2.ellipse(img, kp, (55,55), -90, 0, int(min(angle,135)),
                    (0,255,255), 2, cv2.LINE_AA)

    # Header bar
    cv2.rectangle(img, (0,0), (w,52), (0,0,0), -1)
    ts = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
    cv2.putText(img, f"{side.upper()} Knee — {state.name}  |  {angle:.1f} deg",
                (10, 20), cv2.FONT_HERSHEY_DUPLEX, 0.52, (0,220,220), 1)
    cv2.putText(img, ts, (10, 44),
                cv2.FONT_HERSHEY_DUPLEX, 0.42, (155,155,155), 1)

    # Landmark table bottom-right
    rows = [
        f"Hip    x={lm[hi].x:.3f}  y={lm[hi].y:.3f}  z={lm[hi].z:.3f}",
        f"Knee   x={lm[ki].x:.3f}  y={lm[ki].y:.3f}  z={lm[ki].z:.3f}",
        f"Ankle  x={lm[ai].x:.3f}  y={lm[ai].y:.3f}  z={lm[ai].z:.3f}",
    ]
    by = h - 10 - len(rows) * 20
    cv2.rectangle(img, (w-384, by-8), (w-2, h-2), (20,20,20), -1)
    for i, row in enumerate(rows):
        cv2.putText(img, row, (w-380, by + i*20),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.38, (175,175,175), 1)
    return img


