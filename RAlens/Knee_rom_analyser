def rrect(img, x1, y1, x2, y2, r, color, alpha=0.78):
    ov = img.copy()
    cv2.rectangle(ov, (x1+r, y1), (x2-r, y2), color, -1)
    cv2.rectangle(ov, (x1, y1+r), (x2, y2-r), color, -1)
    for cx, cy in [(x1+r,y1+r),(x2-r,y1+r),(x1+r,y2-r),(x2-r,y2-r)]:
        cv2.circle(ov, (cx,cy), r, color, -1)
    cv2.addWeighted(ov, alpha, img, 1-alpha, 0, img)


def t(img, text, x, y, sc=0.55, col=CW, th=1, bold=False):
    f = cv2.FONT_HERSHEY_DUPLEX
    if bold:
        cv2.putText(img, text, (x, y), f, sc, (0,0,0), th+2)
    cv2.putText(img, text, (x, y), f, sc, col, th)


def arc_gauge(img, cx, cy, rad, angle, max_a=135):
    cv2.ellipse(img, (cx,cy), (rad,rad), -90, 0, max_a,
                (50,50,50), 8, cv2.LINE_AA)
    if angle > 2:
        col = CG if (angle >= THRESH['flexion_mild'] or angle <= THRESH['extension_flag']) else CO
        cv2.ellipse(img, (cx,cy), (rad,rad), -90, 0,
                    int(min(angle, max_a)), col, 8, cv2.LINE_AA)
    ra = np.radians(-90 + min(angle, max_a))
    tx = int(cx + rad * np.cos(ra))
    ty = int(cy + rad * np.sin(ra))
    cv2.circle(img, (tx, ty), 10, CY, -1, cv2.LINE_AA)
    cv2.circle(img, (tx, ty),  5, CW, -1, cv2.LINE_AA)


def draw_skeleton_live(frame, pose_lm, side, w, h, angle):
    P = mp.solutions.pose.PoseLandmark
    if side == 'left':
        hi, ki, ai = P.LEFT_HIP.value, P.LEFT_KNEE.value, P.LEFT_ANKLE.value
    else:
        hi, ki, ai = P.RIGHT_HIP.value, P.RIGHT_KNEE.value, P.RIGHT_ANKLE.value
    lm = pose_lm.landmark
    hp = (int(lm[hi].x*w), int(lm[hi].y*h))
    kp = (int(lm[ki].x*w), int(lm[ki].y*h))
    ap = (int(lm[ai].x*w), int(lm[ai].y*h))
    # glow
    cv2.line(frame, hp, kp, (0,70,0),  10, cv2.LINE_AA)
    cv2.line(frame, kp, ap, (0,55,95),  9, cv2.LINE_AA)
    cv2.line(frame, hp, kp, CG,   4, cv2.LINE_AA)
    cv2.line(frame, kp, ap, CLB,  3, cv2.LINE_AA)
    for pt, col, r in [(hp,CY,9),(kp,CC,13),(ap,CLB,9)]:
        cv2.circle(frame, pt, r+3, (0,0,0), -1, cv2.LINE_AA)
        cv2.circle(frame, pt, r,   col,     -1, cv2.LINE_AA)
    t(frame, f"{angle:.0f}°", kp[0]+14, kp[1]-14, 0.80, CY, 2, bold=True)


