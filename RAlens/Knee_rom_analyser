    # Side badge
    sc = (155,48,0) if result.side == 'left' else (0,68,155)
    rrect(img, 26, 68, 200, 108, 6, sc, alpha=0.92)
    t(img, f"{result.side.upper()} KNEE", 38, 96, 0.64, CW, 2)
    t(img, result.timestamp, WINDOW_W-340, 92, 0.40, (120,120,120), 1)

    y = 116
    cv2.line(img, (26,y), (WINDOW_W-26,y), (36,36,52), 1)
    y += 16

    # Measurements
    t(img, "MEASUREMENTS  (AAOS / AMA 6th Ed.)", 32, y+14, 0.55, CC, 1)
    y += 34

    grade_colors = {
        "NORMAL":   (CG,   (22,38,22)),
