        "MODERATE": (CR,   (44,18,18)),
        "SEVERE":   ((0,0,180), (55,10,10)),
    }

    def mrow(label, val_str, ref_str, grade, yy):
        gc, bg = grade_colors.get(grade, (CW, (25,25,40)))
        rrect(img, 30, yy-20, WINDOW_W-30, yy+12, 4, bg, alpha=0.90)
        t(img, label,            36,           yy, 0.49, CW,  1)
        t(img, val_str,         316,           yy, 0.58, CY,  2)
        t(img, ref_str,         388,           yy, 0.40, CGR, 1)
        t(img, grade, WINDOW_W-122, yy, 0.52, gc, 2)

    arc_ok = result.total_arc >= 100
    imp_ok = result.impairment_pct < 1.5

    mrow("Max Flexion   (bend knee up)",
         f"{result.max_flexion:.0f}°",
         f"normal >= {THRESH['flexion_normal']}°",
         result.flexion_grade, y);   y += 38

    mrow("Min Extension  (straighten down)",
         f"{result.min_extension:.0f}°",
         f"normal <= {THRESH['extension_flag']}°",
         result.extension_grade, y); y += 38

    mrow("Total Arc of Motion",
         f"{result.total_arc:.0f}°",
         "normal >= 120°",
         "NORMAL" if arc_ok else "MODERATE", y); y += 38

    mrow("AMA LE Impairment Estimate",
         f"{result.impairment_pct:.1f}%",
         "normal < 1.5% LE",
         "NORMAL" if imp_ok else ("MILD" if result.impairment_pct < 4 else "MODERATE"),
         y); y += 44

    cv2.line(img, (26,y), (WINDOW_W-26,y), (36,36,52), 1)
    y += 14

    # Clinical summary
    t(img, "CLINICAL SUMMARY", 32, y+14, 0.55, CC, 1)
    y += 32
    notes = result.clinical_notes
    bg2 = (18,42,18) if not result.abnormalities else (44,18,18)
    rrect(img, 30, y-2, WINDOW_W-30, y+len(notes)*28+10, 6, bg2, alpha=0.88)
    nc = CG if not result.abnormalities else CO
    for n in notes:
        t(img, f"  {n}", 40, y+20, 0.47, nc, 1)
        y += 28
    y += 16
    cv2.line(img, (26,y), (WINDOW_W-26,y), (36,36,52), 1)
    y += 14

    # Recommendations
    t(img, "RECOMMENDATIONS", 32, y+14, 0.55, CC, 1)
    y += 32
    if not result.abnormalities:
        recs = ["Continue current treatment and exercise plan.",
                "Routine knee ROM monitoring every 3 months."]
        rc = CG
    elif result.flexion_grade == "SEVERE" or result.extension_grade == "SEVERE":
        recs = ["URGENT: Refer to rheumatologist / orthopaedic specialist.",
                "Physiotherapy: knee mobilisation and strengthening.",
                "Flexion/extension exercises: 4x daily, 15 reps.",
                "Consider bracing if flexion contracture is present."]
        rc = CR
    else:
        recs = ["Clinical evaluation recommended for ROM restriction.",
                "Physiotherapy: knee stretching 3x daily, 10 reps.",
                "Heat therapy before exercises improves ROM.",
                "Reassess in 6 weeks and track progression."]
        rc = CO
    for r in recs:
        t(img, f"  {r}", 40, y+18, 0.46, rc, 1)
        y += 26

    # Timer bar
    bw2 = WINDOW_W - 40
    bf2 = int(bw2 * (secs_left / REPORT_SECS))
    cv2.rectangle(img, (20, WINDOW_H-10), (20+bw2, WINDOW_H-3), (42,42,42), -1)
    cv2.rectangle(img, (20, WINDOW_H-10), (20+bf2,  WINDOW_H-3), CC,         -1)

    return img


