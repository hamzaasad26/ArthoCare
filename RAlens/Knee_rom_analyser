def draw_live(frame, pose_lm, angle, state, side,
              ok, msg, hint, max_flex, min_ext,
              countdown, stable, w, h):

    draw_skeleton_live(frame, pose_lm, side, w, h, angle)

    # TOP BAR
    rrect(frame, 0, 0, w, 70, 0, (14,14,24), alpha=0.90)
    steps = {
        TestState.NEUTRAL_BASELINE: ("STEP 1 / 3", "Stand STRAIGHT — leg fully extended at side"),
        TestState.EXTENSION_TEST:   ("STEP 2 / 3", "STRAIGHTEN knee — push leg back to 0°"),
        TestState.FLEXION_TEST:     ("STEP 3 / 3", "BEND knee — lift heel UP toward buttock"),
    }
    sl, si_ = steps.get(state, ("", ""))
    t(frame, sl,  14, 26, 0.52, CC, 1)
    t(frame, si_, 14, 56, 0.60, CW, 1)

    # Side badge
    bc = (155, 48, 0) if side == 'left' else (0, 68, 155)
    rrect(frame, w-132, 6, w-6, 64, 6, bc, alpha=0.92)
    t(frame, f"{side.upper()} LEG", w-124, 44, 0.64, CW, 2)

    # Camera hint
    rrect(frame, w-310, 70, w-6, 108, 4, (30,30,50), alpha=0.85)
    t(frame, "Side-profile to camera", w-300, 96, 0.44, (180,180,180), 1)

    # ARC GAUGE
    gcx, gcy = w-92, h-118
    arc_gauge(frame, gcx, gcy, 70, angle)
    t(frame, f"{angle:.0f}°", gcx-22, gcy+20, 0.80, CY, 2, bold=True)
    t(frame, "ANGLE",         gcx-26, gcy+42, 0.42, CW,  1)

    # POSTURE FEEDBACK
    fy = h - 108
    rrect(frame, 8, fy, 535, h-8, 8,
          (0,52,0) if ok else (52,0,0), alpha=0.80)
    t(frame, msg,  18, fy+30, 0.58, CG if ok else CR, 2)
    if hint:
        t(frame, hint, 18, fy+58, 0.50, CO, 1)

    # PROGRESS BARS
    rrect(frame, 8, 82, 222, 235, 8, (18,18,32), alpha=0.80)
    t(frame, "PROGRESS", 18, 106, 0.48, CC, 1)
    bw = 194

    ext_v = min_ext if min_ext < 180 else 0.0
    t(frame, f"Extension: {ext_v:.0f}°", 18, 134, 0.44, CW, 1)
    ep_frac = max(0.0, 1.0 - ext_v / 50.0)
    cv2.rectangle(frame, (18,142), (18+bw,154), (45,45,45), -1)
    cv2.rectangle(frame, (18,142), (18+int(bw*ep_frac),154),
                  CG if ext_v <= THRESH['extension_flag'] else CO, -1)

    t(frame, f"Flexion:   {max_flex:.0f}°", 18, 178, 0.44, CW, 1)
    fp_frac = min(max_flex / THRESH['flexion_normal'], 1.0)
    cv2.rectangle(frame, (18,186), (18+bw,198), (45,45,45), -1)
    cv2.rectangle(frame, (18,186), (18+int(bw*fp_frac),198),
                  CG if max_flex >= THRESH['flexion_mild'] else CO, -1)

    # COUNTDOWN
    if countdown is not None and countdown > 0:
        rrect(frame, w//2-110, h//2-50, w//2+110, h//2+50, 14,
              (0, 90, 0), alpha=0.92)
        t(frame, "Capturing...", w//2-88, h//2-10, 0.72, CG, 2, bold=True)
        t(frame, f"{countdown:.1f}s", w//2-38, h//2+32, 0.80, CY, 2, bold=True)
    elif stable and ok:
        t(frame, "STABLE", w-165, 110, 0.52, CG, 2)
    else:
        t(frame, "Stabilising...", w-210, 110, 0.46, CO, 1)

    return frame


# ═══════════════════════════════════════════════════════════════
#  TRANSITION SCREEN
# ═══════════════════════════════════════════════════════════════

def draw_transition(cap, seconds=INTER_LEG_SEC):
    deadline = time.time() + seconds
    while time.time() < deadline:
        ret, raw = cap.read()
        frame = cv2.resize(cv2.flip(raw, 1) if ret else
                           np.zeros((WINDOW_H, WINDOW_W, 3), np.uint8),
                           (WINDOW_W, WINDOW_H))
        overlay = frame.copy()
        cv2.rectangle(overlay, (0,0), (WINDOW_W, WINDOW_H), (0,0,0), -1)
        cv2.addWeighted(overlay, 0.75, frame, 0.25, 0, frame)

        secs_left = deadline - time.time()
        t(frame, "LEFT LEG COMPLETE",
          WINDOW_W//2 - 168, WINDOW_H//2 - 55, 0.88, CG, 2, bold=True)
        t(frame, f"Starting RIGHT leg in  {secs_left:.0f}s ...",
          WINDOW_W//2 - 210, WINDOW_H//2 + 10, 0.72, CC, 2)
        t(frame, "Turn around — RIGHT side to camera",
          WINDOW_W//2 - 195, WINDOW_H//2 + 55, 0.58, CW, 1)

        bw = WINDOW_W - 40
        bf = int(bw * (secs_left / seconds))
        cv2.rectangle(frame, (20, WINDOW_H-14), (20+bw, WINDOW_H-4), (45,45,45), -1)
        cv2.rectangle(frame, (20, WINDOW_H-14), (20+bf,  WINDOW_H-4), CC, -1)

        cv2.imshow("Knee ROM Analyzer", frame)
        if (cv2.waitKey(40) & 0xFF) == ord('q'):
            return False
    return True


