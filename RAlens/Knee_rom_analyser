# ═══════════════════════════════════════════════════════════════
#  GEOMETRY — Knee angle
# ═══════════════════════════════════════════════════════════════

def knee_angle(hip, knee, ankle) -> float:
    """
    Flexion angle at knee:
    0°   = fully straight leg
    135° = fully bent (heel near buttock)
    Uses 3-point angle at knee joint.
    """
    v1 = hip   - knee
    v2 = ankle - knee
    n1, n2 = np.linalg.norm(v1), np.linalg.norm(v2)
    if n1 < 1e-6 or n2 < 1e-6:
        return 0.0
    cos_a    = np.clip(np.dot(v1 / n1, v2 / n2), -1.0, 1.0)
    interior = np.degrees(np.arccos(cos_a))   # 180° = straight
    return max(0.0, 180.0 - interior)


# ═══════════════════════════════════════════════════════════════
#  LANDMARK HELPER
# ═══════════════════════════════════════════════════════════════

def get_leg(pose_lm, side: str):
    """
    Returns hip, knee, ankle numpy arrays for given side.
    NOTE: For side-profile testing, we use the visible leg.
    Left side test  → use LEFT  landmarks (patient's left side toward camera)
    Right side test → use RIGHT landmarks (patient's right side toward camera)
    Camera is flipped so MediaPipe left/right matches user's side facing camera.
    """
    P = mp.solutions.pose.PoseLandmark
    if side == 'left':
        hi, ki, ai = P.LEFT_HIP.value, P.LEFT_KNEE.value, P.LEFT_ANKLE.value
    else:
        hi, ki, ai = P.RIGHT_HIP.value, P.RIGHT_KNEE.value, P.RIGHT_ANKLE.value
    lm  = pose_lm.landmark
    hp  = np.array([lm[hi].x, lm[hi].y, lm[hi].z])
    kp  = np.array([lm[ki].x, lm[ki].y, lm[ki].z])
    ap  = np.array([lm[ai].x, lm[ai].y, lm[ai].z])
    vis = min(lm[hi].visibility, lm[ki].visibility, lm[ai].visibility)
    return hp, kp, ap, vis, hi, ki, ai


# ═══════════════════════════════════════════════════════════════
#  POSTURE VALIDATION + DIRECTIONAL GUIDANCE
# ═══════════════════════════════════════════════════════════════

def validate(angle: float, state: TestState) -> Tuple[bool, str, str]:
    """Returns (ok, status_message, direction_hint)"""

    if state == TestState.NEUTRAL_BASELINE:
        if angle <= THRESH['neutral_max']:
            return True,  f"Good — leg straight  ({angle:.0f}°)", ""
        diff = angle - THRESH['neutral_max']
        return False, \
               f"Straighten leg  ({angle:.0f}°  need < {THRESH['neutral_max']}°)", \
               f"  Straighten your knee — let leg hang relaxed"

    elif state == TestState.EXTENSION_TEST:
        if angle <= THRESH['extension_flag']:
            return True,  f"Good extension  ({angle:.0f}°)", ""
        elif angle <= 35:
            return True,  f"Keep straightening  ({angle:.0f}°)", \
                          f"  Push knee back — try to reach 0°"
        else:
            return False, f"Bend in knee  ({angle:.0f}°  need < {THRESH['extension_flag']}°)", \
                          f"  Straighten your knee fully — push back"

    elif state == TestState.FLEXION_TEST:
        if angle >= 100:
            return True,  f"Good flexion  ({angle:.0f}°)", ""
        elif angle >= 60:
            return True,  f"Keep bending  ({angle:.0f}°)", \
                          f"  Lift heel UP — bend knee more"
        elif angle >= 30:
            return False, f"Bend knee more  ({angle:.0f}°  need > 60°)", \
                          f"  Lift heel toward buttock — bend at knee"
        else:
            return False, f"Start bending knee  ({angle:.0f}°)", \
                          f"  Raise heel UP — bend your knee joint"

    return True, "Position OK", ""


# ═══════════════════════════════════════════════════════════════
#  MEDICAL GRADING
# ═══════════════════════════════════════════════════════════════

def grade_flexion(angle: float) -> Tuple[str, float, str]:
    deficit = max(0.0, THRESH['flexion_normal'] - angle)
    if angle >= THRESH['flexion_mild']:
        return "NORMAL",   deficit, "Flexion within AAOS normal limits."
    elif angle >= THRESH['flexion_moderate']:
        return "MILD",     deficit, f"Mild flexion restriction — {deficit:.0f}° below normal. Monitor."
    elif angle >= THRESH['flexion_severe']:
        return "MODERATE", deficit, f"Moderate flexion restriction — {deficit:.0f}° deficit. Physiotherapy indicated."
    else:
        return "SEVERE",   deficit, f"Severe flexion restriction — {deficit:.0f}° deficit. Urgent evaluation."


def grade_extension(angle: float) -> Tuple[str, float, str]:
    deficit = max(0.0, angle)
    if angle <= THRESH['extension_flag']:
        return "NORMAL", deficit, "Extension within AAOS normal limits."
    elif angle <= THRESH['extension_severe']:
        return "MILD",   deficit, f"Mild flexion contracture — {deficit:.0f}° extension deficit."
    else:
        return "SEVERE", deficit, f"Significant flexion contracture — {deficit:.0f}° deficit. Referral advised."


def estimate_impairment(total_arc: float) -> float:
    """AMA Guides 6th Ed. — max knee lower-extremity contribution ~7%."""
    full_arc = 135.0
    return round(max(0.0, (1.0 - min(total_arc / full_arc, 1.0)) * 7.0), 1)


