#  SINGLE LEG ANALYZER
# ═══════════════════════════════════════════════════════════════

class LegAnalyzer:
    def __init__(self, cap, pose, side, pid, out):
        self.cap      = cap
        self.pose     = pose
        self.side     = side
        self.pid      = pid
        self.out      = out
        self.state    = TestState.NEUTRAL_BASELINE
        self.max_flex = 0.0
        self.min_ext  = 180.0
        self.neutral  = 0.0
        self.buf      = deque(maxlen=STAB['buf'])
        self.hist     = []
        self.hold_t   = None

    def _stable(self, a: float) -> bool:
        self.buf.append(a)
        if len(self.buf) < STAB['buf']:
            return False
        return float(np.var(list(self.buf))) < STAB['variance']

    def _plateaued(self, a: float) -> bool:
        if self.state not in (TestState.FLEXION_TEST, TestState.EXTENSION_TEST):
            return True
        self.hist.append(a)
        if len(self.hist) > STAB['plateau_win']:
            self.hist.pop(0)
        if len(self.hist) < STAB['plateau_win']:
            return False
        recent  = float(np.mean(self.hist[-5:]))
        earlier = float(np.mean(self.hist[:5]))
        return abs(recent - earlier) < STAB['plateau_tol']

    def _capture_advance(self, frame, pose_lm, angle):
        ann   = annotated_capture(frame, pose_lm, self.side,
                                  angle, self.state, WINDOW_W, WINDOW_H)
        fname = os.path.join(
            self.out,
            f"{self.pid}_{self.side}_{self.state.name}_{angle:.0f}deg.jpg"
        )
        cv2.imwrite(fname, ann)
        print(f"  📸 {fname}")

        if   self.state == TestState.NEUTRAL_BASELINE:
            self.neutral = angle
            self.state   = TestState.EXTENSION_TEST
        elif self.state == TestState.EXTENSION_TEST:
            self.state   = TestState.FLEXION_TEST
        elif self.state == TestState.FLEXION_TEST:
            self.state   = TestState.COMPLETE

        self.hold_t = None
        self.buf.clear()
        self.hist.clear()

    def _show_intro(self):
        """2.5 second intro telling user which leg and camera position."""
        deadline = time.time() + 2.5
        while time.time() < deadline:
            ret, raw = self.cap.read()
            frame = cv2.resize(
                cv2.flip(raw, 1) if ret else np.zeros((WINDOW_H,WINDOW_W,3), np.uint8),
                (WINDOW_W, WINDOW_H)
            )
            ov = frame.copy()
            cv2.rectangle(ov, (0,0),(WINDOW_W,WINDOW_H),(0,0,0),-1)
            cv2.addWeighted(ov, 0.72, frame, 0.28, 0, frame)

            bc = (155,48,0) if self.side=='left' else (0,68,155)
            rrect(frame, WINDOW_W//2-220, WINDOW_H//2-70,
                  WINDOW_W//2+220, WINDOW_H//2+70, 16, bc, alpha=0.92)
            t(frame, f"Testing  {self.side.upper()}  KNEE",
              WINDOW_W//2-190, WINDOW_H//2-15, 0.88, CW, 2, bold=True)
            t(frame, f"Stand with {self.side.upper()} side toward camera",
              WINDOW_W//2-215, WINDOW_H//2+30, 0.56, CW, 1)
            t(frame, "Full body visible in frame",
              WINDOW_W//2-155, WINDOW_H//2+58, 0.50, (180,180,180), 1)

            cv2.imshow("Knee ROM Analyzer", frame)
            if (cv2.waitKey(40) & 0xFF) == ord('q'):
                return False
        return True

    def run(self) -> Optional[KneeResult]:
        if not self._show_intro():
            return None

        while True:
            ret, raw = self.cap.read()
            if not ret:
                break

            raw   = cv2.flip(raw, 1)
            frame = cv2.resize(raw, (WINDOW_W, WINDOW_H))
            rgb   = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            res   = self.pose.process(rgb)

            # COMPLETE → show report
            if self.state == TestState.COMPLETE:
                result   = analyze(self.neutral, self.max_flex, self.min_ext, self.side)
                deadline = time.time() + REPORT_SECS
                while time.time() < deadline:
                    sl = deadline - time.time()
                    cv2.imshow("Knee ROM Analyzer",
                               draw_report_screen(result, sl))
                    k = cv2.waitKey(40) & 0xFF
                    if k == ord('q'):
                        return result
                return result

            # ACTIVE TEST
            if res.pose_landmarks:
                hp, kp, ap, vis, *_ = get_leg(res.pose_landmarks, self.side)

                if vis > 0.35:
                    a = knee_angle(hp, kp, ap)

                    if self.state == TestState.FLEXION_TEST:
                        self.max_flex = max(self.max_flex, a)
                    if self.state == TestState.EXTENSION_TEST:
                        self.min_ext  = min(self.min_ext, a)

                    ok, msg, hint = validate(a, self.state)
                    stable    = self._stable(a)
                    plateaued = self._plateaued(a)
                    ready     = ok and stable and plateaued

                    countdown = None
                    if ready:
                        if self.hold_t is None:
                            self.hold_t = time.time()
                        remaining = STAB['hold_sec'] - (time.time() - self.hold_t)
                        countdown = max(0.0, remaining)
                        if remaining <= 0:
                            self._capture_advance(frame.copy(), res.pose_landmarks, a)
                            continue
                    else:
                        self.hold_t = None

                    frame = draw_live(
                        frame, res.pose_landmarks, a, self.state, self.side,
                        ok, msg, hint, self.max_flex, self.min_ext,
                        countdown, stable, WINDOW_W, WINDOW_H
                    )
                else:
                    rrect(frame, 8, WINDOW_H-68, 560, WINDOW_H-8, 6, (52,0,0), 0.8)
                    t(frame, "Low visibility — step back / improve lighting",
                      18, WINDOW_H-30, 0.56, CR, 2)
            else:
                rrect(frame, 8, WINDOW_H-68, 580, WINDOW_H-8, 6, (52,0,0), 0.8)
                t(frame, "Body not detected — ensure full leg is visible",
                  18, WINDOW_H-30, 0.56, CR, 2)

            cv2.imshow("Knee ROM Analyzer", frame)
            k = cv2.waitKey(10) & 0xFF
            if k == ord('q'):
                return None
            elif k == ord('r'):
                self.state    = TestState.NEUTRAL_BASELINE
                self.max_flex = 0.0
                self.min_ext  = 180.0
                self.buf.clear()
                self.hist.clear()
                self.hold_t = None

        return None


