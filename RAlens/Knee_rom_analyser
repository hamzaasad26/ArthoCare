#  CLINICAL ANALYSIS
# ═══════════════════════════════════════════════════════════════

def analyze(neutral, max_flex, min_ext, side) -> KneeResult:
    fg, fd, fn = grade_flexion(max_flex)
    eg, ed, en = grade_extension(min_ext)
    total_arc  = max(0.0, max_flex - min_ext)
    impairment = estimate_impairment(total_arc)

    abn, notes = [], []
    if fg != "NORMAL":
        abn.append(f"Reduced flexion: {max_flex:.0f}° [{fg}] — {fn}")
    if eg != "NORMAL":
        abn.append(f"Extension restriction: {min_ext:.0f}° [{eg}] — {en}")
    notes.append(fn)
    notes.append(en)
    if not abn:
        notes.append(f"Total arc {total_arc:.0f}° — full functional ROM maintained.")

    return KneeResult(
        side=side, neutral_angle=neutral,
        max_flexion=max_flex, min_extension=min_ext,
        flexion_grade=fg, extension_grade=eg,
        flexion_deficit=fd, extension_deficit=ed,
        total_arc=total_arc, impairment_pct=impairment,
        timestamp=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        abnormalities=abn, clinical_notes=notes
    )


# ═══════════════════════════════════════════════════════════════
#  REPORT SAVING
# ═══════════════════════════════════════════════════════════════

def save_report(folder, pid, left_r: Optional[KneeResult],
                right_r: Optional[KneeResult]):
    os.makedirs(folder, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # JSON
    bilateral = None
    if left_r and right_r:
        df = abs(left_r.max_flexion   - right_r.max_flexion)
        de = abs(left_r.min_extension - right_r.min_extension)
        bilateral = {
            "flexion_difference_deg":   round(df, 1),
            "extension_difference_deg": round(de, 1),
            "asymmetry_flag":           df > 15 or de > 10,
            "clinical_note": "Difference >15° flexion or >10° extension is clinically significant."
        }

    jp = os.path.join(folder, f"{pid}_knee_report.json")
    with open(jp, 'w') as f:
        json.dump({
            "patient_id":  pid,
            "test_date":   ts,
            "standard":    "AAOS / AMA Guides 6th Edition — Knee ROM",
            "left_knee":   asdict(left_r)  if left_r  else None,
            "right_knee":  asdict(right_r) if right_r else None,
            "bilateral_comparison": bilateral,
            "normal_reference": {
                "flexion_normal_deg":      THRESH['flexion_normal'],
                "flexion_mild_flag_deg":   THRESH['flexion_mild'],
                "flexion_moderate_deg":    THRESH['flexion_moderate'],
                "flexion_severe_deg":      THRESH['flexion_severe'],
                "extension_normal_deg":    0,
                "extension_flag_deg":      THRESH['extension_flag'],
                "extension_severe_deg":    THRESH['extension_severe'],
                "ama_max_le_contribution_pct": 7.0,
            }
        }, f, indent=2)

    # TXT
    SEP = "=" * 64
    tp  = os.path.join(folder, f"{pid}_knee_summary.txt")
    with open(tp, 'w', encoding='utf-8') as f:
        f.write(SEP + "\n  KNEE ROM ANALYSIS REPORT\n")
        f.write("  Standard: AAOS / AMA Guides 6th Edition\n" + SEP + "\n")
        f.write(f"  Patient ID  : {pid}\n  Test Date   : {ts}\n" + SEP + "\n\n")

        for res, lbl in [(left_r,"LEFT KNEE"), (right_r,"RIGHT KNEE")]:
            if not res:
                continue
            f.write(f"  {lbl}\n  " + "─"*44 + "\n")
            f.write(f"  Neutral Baseline  : {res.neutral_angle:.1f}°"
                    f"   (normal <= {THRESH['neutral_max']}°)\n")
            f.write(f"  Max Flexion       : {res.max_flexion:.1f}°"
                    f"   (normal >= {THRESH['flexion_normal']}°)"
                    f"   Grade: {res.flexion_grade}"
                    f"   Deficit: {res.flexion_deficit:.0f}°\n")
            f.write(f"  Min Extension     : {res.min_extension:.1f}°"
                    f"   (normal <= {THRESH['extension_flag']}°)"
                    f"   Grade: {res.extension_grade}"
                    f"   Deficit: {res.extension_deficit:.0f}°\n")
            f.write(f"  Total Arc         : {res.total_arc:.1f}°"
                    f"   (normal >= 120°)\n")
            f.write(f"  AMA LE Impairment : {res.impairment_pct:.1f}%"
                    f"   (normal < 1.5%)\n")
            status = "NORMAL" if not res.abnormalities else "RESTRICTION DETECTED"
            f.write(f"  Overall Status    : {status}\n")
            if res.abnormalities:
                f.write("\n  Abnormalities:\n")
                for a in res.abnormalities:
                    f.write(f"    - {a}\n")
            f.write("\n  Clinical Notes:\n")
            for n in res.clinical_notes:
                f.write(f"    {n}\n")
            f.write("\n")

        if bilateral:
            f.write("  BILATERAL COMPARISON\n  " + "─"*44 + "\n")
            f.write(f"  Flexion  difference : {bilateral['flexion_difference_deg']:.1f}°"
                    f"   {'FLAG: asymmetry > 15°' if bilateral['asymmetry_flag'] else 'within normal'}\n")
            f.write(f"  Extension difference: {bilateral['extension_difference_deg']:.1f}°\n\n")

        all_abn = []
        if left_r  and left_r.abnormalities:  all_abn += left_r.abnormalities
        if right_r and right_r.abnormalities: all_abn += right_r.abnormalities
        f.write("  RECOMMENDATIONS\n  " + "─"*44 + "\n")
        if not all_abn:
            f.write("  - Knee ROM normal bilaterally.\n")
            f.write("  - Continue current treatment plan.\n")
            f.write("  - Routine ROM check every 3 months.\n")
        else:
            severe = any("SEVERE" in a for a in all_abn)
            if severe:
                f.write("  - URGENT: Refer to rheumatologist / orthopaedic specialist.\n")
                f.write("  - Consider bracing for flexion contracture correction.\n")
            f.write("  - Physiotherapy: knee mobilisation and strengthening.\n")
            f.write("  - Exercises: flexion/extension 3-4x daily, 10-15 reps.\n")
            f.write("  - Heat therapy before exercises recommended.\n")
            f.write("  - Reassess ROM in 4-6 weeks.\n")

        f.write("\n  AAOS / AMA REFERENCE\n  " + "─"*44 + "\n")
        f.write(f"  Flexion   : 0° to {THRESH['flexion_normal']}°\n")
        f.write(f"  Extension : return to 0°  (flag if > {THRESH['extension_flag']}°)\n")
        f.write( "  Grades    : NORMAL / MILD / MODERATE / SEVERE\n")
        f.write(SEP + "\n")

    print(f"  📄 TXT  -> {tp}")
    print(f"  📊 JSON -> {jp}")


